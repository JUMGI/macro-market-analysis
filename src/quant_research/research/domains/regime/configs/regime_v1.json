{
  "name": "regime_v1",

  "model": {
    "type": "rule_based",

    "temperature": {
      "param": "temperature"
    },

    "regimes": [
      {
        "name": "bull",
        "rules": [
          {
            "conditions": [
              {
                "feature": "mom_mean_raw",
                "op": ">",
                "value": { "param": "threshold" },
                "scale": { "param": "scale" }
              },
              {
                "feature": "mom_breadth_from_z",
                "op": ">",
                "value": { "param": "breadth_threshold" },
                "scale": { "param": "breadth_scale" }
              }
            ]
          }
        ]
      },
      {
        "name": "bear",
        "rules": [
          {
            "conditions": [
              {
                "feature": "mom_mean_raw",
                "op": "<",
                "value": { "param": "threshold" },
                "scale": { "param": "scale" }
              }
            ]
          }
        ]
      }
    ]
  },

  "processors": [
    {
      "type": "rolling_mean",
      "params": {
        "window": 5
      }
    }
  ],

  "search_space": {
    "features": {
      "mom_mean_raw": {
        "type": "top_k",
        "k": 3
      },
      "mom_breadth_from_z": {
        "type": "top_k",
        "k": 2
      }
    },

    "params": {
      "threshold": {
        "type": "grid",
        "values": [0.0, 0.01, 0.02]
      },
      "breadth_threshold": {
        "type": "grid",
        "values": [0.5, 0.6, 0.7]
      },
      "scale": {
        "type": "grid",
        "values": [0.01, 0.02]
      },
      "breadth_scale": {
        "type": "grid",
        "values": [0.1, 0.2]
      },
      "temperature": {
        "type": "fixed",
        "values": [0.7]
      }
    }
  }
}